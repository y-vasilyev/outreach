// Prisma schema for Nosquare Outreach
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============== ENUMS ===============

enum UserRole {
  admin
  operator
  viewer
}

enum Platform {
  telegram
  instagram
  youtube
}

enum TgAccountStatus {
  idle
  active
  cooldown
  banned
  need_auth
}

enum TgAccountRole {
  parser
  outreach
  both
}

enum LLMProviderKind {
  yandex
  openrouter
  openai_compat
}

enum ChannelStatus {
  new
  scraping
  scraped
  extracting
  extracted
  ready
  done
  failed
}

enum ContactType {
  tg_username
  tg_phone
  tg_link
  email
  website
  web_form
  other
}

enum RoleGuess {
  owner
  ad_manager
  generic
  bot
  unknown
}

enum Reachability {
  reachable_tg
  manual
  unreachable
}

enum ContactStatus {
  new
  qualified
  disqualified
  contacted
  active
  finished
  invalid
  blocked
}

enum ExtractedBy {
  regex
  llm
  both
  // Operator hand-edited the contact (role / confidence / value).
  // The contact-extract worker checks this and skips overwriting on re-run.
  manual
}

enum CampaignStatus {
  draft
  running
  paused
  finished
}

enum ConversationMode {
  auto
  semi_auto
  assisted
  manual
}

enum ConversationStatus {
  active
  paused
  done
  failed
}

enum MessageDirection {
  in_
  out_
}

enum MessageSender {
  contact
  ai
  operator
  system
}

enum MessageStatus {
  pending
  sending
  sent
  failed
  received
}

enum SuggestionStatus {
  pending
  approved
  edited
  rejected
  sent
  expired
}

enum AgentRunStatus {
  ok
  fallback
  failed
}

// =============== MODELS ===============

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(operator)
  settings     Json     @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  channelsAdded         Channel[]            @relation("ChannelAddedBy")
  conversationsAssigned Conversation[]       @relation("ConversationOperator")
  messages              Message[]
  campaigns             Campaign[]
  agentConfigsUpdated   AgentConfig[]        @relation("AgentConfigUpdatedBy")
  agentConfigHistories  AgentConfigHistory[] @relation("AgentConfigHistoryChangedBy")
  auditLogs             AuditLog[]
}

model TgAccount {
  id                   String          @id @default(cuid())
  label                String
  phone                String          @unique
  sessionEncrypted     String?
  status               TgAccountStatus @default(need_auth)
  role                 TgAccountRole   @default(both)
  dailyMsgLimit        Int             @default(30)
  dailyNewContactLimit Int             @default(15)
  sentTodayMsg         Int             @default(0)
  sentTodayNew         Int             @default(0)
  dayRolledAt          DateTime?
  cooldownUntil        DateTime?
  warmupStartedAt      DateTime?
  warmupStage          Int             @default(0)
  tags                 String[]        @default([])
  notes                String?
  loginPhoneCodeHash   String?
  deviceFingerprint    Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  conversations Conversation[]
  opLogs        TgOpLog[]
}

model Integration {
  id              String    @id @default(cuid())
  kind            String    @unique
  configEncrypted String
  enabled         Boolean   @default(true)
  status          String?
  lastCheckAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Endpoint {
  id             String          @id @default(cuid())
  name           String          @unique
  provider       LLMProviderKind
  baseUrl        String
  authEncrypted  String
  defaultHeaders Json            @default("{}")
  rateLimitRpm   Int?
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  agentConfigsPrimary  AgentConfig[] @relation("AgentEndpointPrimary")
  agentConfigsFallback AgentConfig[] @relation("AgentEndpointFallback")
  agentRuns            AgentRun[]
}

model Channel {
  id          String        @id @default(cuid())
  platform    Platform
  externalId  String?
  handle      String
  title       String?
  description String?
  links       String[]      @default([])
  followers   Int?
  language    String?
  rawData     Json?
  analysis    Json?
  status      ChannelStatus @default(new)
  source      String        @default("manual")
  addedById   String?
  addedBy     User?         @relation("ChannelAddedBy", fields: [addedById], references: [id], onDelete: SetNull)
  scrapedAt   DateTime?
  lastError   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contacts  Contact[]
  agentRuns AgentRun[]

  @@unique([platform, externalId])
  @@unique([platform, handle])
  @@index([status])
}

model Contact {
  id           String        @id @default(cuid())
  // Optional so the operator can paste cold leads that don't belong to a
  // tracked channel. Cold-lead dedupe is handled by a partial unique index
  // `(type, value) WHERE channelId IS NULL` defined in migration 2.
  channelId    String?
  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  type         ContactType
  value        String
  rawValue     String
  label        String?
  roleGuess    RoleGuess     @default(unknown)
  confidence   Decimal       @default(0)
  extractedBy  ExtractedBy   @default(regex)
  reachability Reachability  @default(manual)
  status       ContactStatus @default(new)
  tags         String[]      @default([])
  tgUserId     String?
  // Resolved on the first outbound send (via TgClient.resolveUser). Stored
  // so the opener / reply pipelines can address the recipient by name and
  // so the tg-listen worker can match incoming messages back to the contact.
  tgUsername   String?
  tgFirstName  String?
  tgLastName   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  conversations Conversation[]
  agentRuns     AgentRun[]

  @@unique([channelId, type, value])
  @@index([status, reachability])
}

model Campaign {
  id                  String           @id @default(cuid())
  name                String
  goalText            String
  valueProp           String
  // Campaign type from the registry (agency-sourcing-matching change).
  // Required as of migration 7 (backfill in migration 6 set every existing
  // campaign to `custdev`). RESTRICT: a campaign type in use can't be deleted.
  // The legacy `ajtbd` JSON column was removed by migration
  // `9c_drop_campaign_ajtbd` — the AJTBD shape for CustDev now lives
  // inside `goal`, mediated by `extractAjtbdView` for the agents that
  // still consume `CampaignAjtbd` as input.
  typeId              String
  type                CampaignType     @relation(fields: [typeId], references: [id], onDelete: Restrict)
  // Structured goal validated against the type's `goalSchema`. For
  // `custdev` this mirrors the legacy `ajtbd` shape; for `agency_sourcing`
  // it carries the data-collection objective. The runtime fails explicitly
  // if it is null when an agent needs it (no hardcoded fallback).
  goal                Json?
  targetFilter        Json             @default("{}")
  agentOverrides      Json             @default("{}")
  outreachAccountPool String[]         @default([])
  schedule            Json             @default("{}")
  defaultMode         ConversationMode @default(assisted)
  status              CampaignStatus   @default(draft)
  createdById         String?
  createdBy           User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  conversations Conversation[]

  @@index([typeId])
}

model Conversation {
  id                 String             @id @default(cuid())
  tgAccountId        String
  tgAccount          TgAccount          @relation(fields: [tgAccountId], references: [id])
  contactId          String
  contact            Contact            @relation(fields: [contactId], references: [id])
  campaignId         String?
  campaign           Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  status             ConversationStatus @default(active)
  mode               ConversationMode   @default(assisted)
  assignedOperatorId String?
  assignedOperator   User?              @relation("ConversationOperator", fields: [assignedOperatorId], references: [id], onDelete: SetNull)
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  // Latest snapshot from the GoalFitEvaluator gate when the conversation
  // is in `semi_auto`/`auto` mode: { score, action, reasons[],
  // agentRunId, decidedAt }. Cleared on any operator-driven mode change.
  qualityDecision    Json?
  // Set whenever the API on-open sync (`ConversationSync.syncOne`)
  // successfully fetches history for this peer. Used by the inbox UI's
  // "Syncing…" hint and by metrics that detect stale push coverage.
  lastSyncedAt       DateTime?
  summary            String?
  meta               Json               @default("{}")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  messages    Message[]
  suggestions Suggestion[]
  agentRuns   AgentRun[]

  @@unique([tgAccountId, contactId])
  @@index([lastInboundAt])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tgMsgId        String?
  direction      MessageDirection
  sender         MessageSender
  text           String
  attachments    Json             @default("[]")
  status         MessageStatus    @default(pending)
  suggestionId   String?
  suggestion     Suggestion?      @relation(fields: [suggestionId], references: [id], onDelete: SetNull)
  operatorId     String?
  operator       User?            @relation(fields: [operatorId], references: [id], onDelete: SetNull)
  sentAt         DateTime?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
}

model Suggestion {
  id             String           @id @default(cuid())
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentName      String
  text           String
  rationale      String           @default("")
  score          Decimal          @default(0)
  status         SuggestionStatus @default(pending)
  meta           Json             @default("{}")
  createdAt      DateTime         @default(now())
  expiresAt      DateTime?

  messages Message[]

  @@index([conversationId, status])
}

model AgentConfig {
  id                 String    @id @default(cuid())
  name               String    @unique
  role               String    @default("")
  description        String    @default("")
  endpointId         String?
  endpoint           Endpoint? @relation("AgentEndpointPrimary", fields: [endpointId], references: [id], onDelete: SetNull)
  fallbackEndpointId String?
  fallbackEndpoint   Endpoint? @relation("AgentEndpointFallback", fields: [fallbackEndpointId], references: [id], onDelete: SetNull)
  model              String    @default("")
  systemPrompt       String    @default("")
  userPromptTemplate String    @default("")
  params             Json      @default("{}")
  enabled            Boolean   @default(true)
  version            Int       @default(1)
  updatedById        String?
  updatedBy          User?     @relation("AgentConfigUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt          DateTime  @updatedAt
  createdAt          DateTime  @default(now())

  history AgentConfigHistory[]
}

model AgentConfigHistory {
  id            String      @id @default(cuid())
  agentConfigId String
  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id], onDelete: Cascade)
  version       Int
  snapshot      Json
  changedById   String?
  changedBy     User?       @relation("AgentConfigHistoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  changedAt     DateTime    @default(now())
}

model AgentRun {
  id             String         @id @default(cuid())
  agentName      String
  channelId      String?
  channel        Channel?       @relation(fields: [channelId], references: [id], onDelete: SetNull)
  contactId      String?
  contact        Contact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  endpointId     String?
  endpoint       Endpoint?      @relation(fields: [endpointId], references: [id], onDelete: SetNull)
  model          String?
  input          Json
  output         Json?
  tokensIn       Int            @default(0)
  tokensOut      Int            @default(0)
  costUsd        Decimal        @default(0)
  latencyMs      Int            @default(0)
  status         AgentRunStatus @default(ok)
  error          String?
  createdAt      DateTime       @default(now())

  @@index([agentName, createdAt])
}

model TgOpLog {
  id          String    @id @default(cuid())
  tgAccountId String
  tgAccount   TgAccount @relation(fields: [tgAccountId], references: [id], onDelete: Cascade)
  op          String
  ok          Boolean
  latencyMs   Int       @default(0)
  error       String?
  meta        Json      @default("{}")
  createdAt   DateTime  @default(now())

  @@index([tgAccountId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String?
  payload    Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

// =============== AGENCY SOURCING & MATCHING ===============
// (agency-sourcing-matching change)

enum MediaAssetKind {
  media_kit
  screenshot
  document
  image
  video
  raw_payload
  other
}

// Configurable campaign type. Drives which agents run, the safety
// profile (allowed/forbidden vocabulary), the autonomy policy, and the
// JSON-schema a campaign's `goal` is validated against.
model CampaignType {
  id             String   @id @default(cuid())
  key            String   @unique
  name           String
  description    String   @default("")
  goalSchema     Json     @default("{}")
  agentSet       Json     @default("{}")
  safetyProfile  Json     @default("{}")
  autonomyPolicy Json     @default("{}")
  builtIn        Boolean  @default(false)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaigns Campaign[]
}

// Runtime feature flag (runtime-feature-flags change). Source of truth for
// operational rollout/kill switches; toggled from the admin UI, cached in
// each process and invalidated via Redis pub/sub. `updatedById` is a plain
// column (the actor + change are also recorded in audit_log).
model FeatureFlag {
  key         String   @id
  enabled     Boolean  @default(false)
  description String   @default("")
  updatedById String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// Batch channel discovery (batch-channel-discovery change). One row per
// async batch request: stores the input niches + accumulated per-niche
// results so the worker can iterate, the API can poll status, and the
// operator can come back to a long-running batch hours later.
enum DiscoveryBatchStatus {
  pending
  running
  done
  failed
}

model DiscoveryBatch {
  id            String               @id @default(cuid())
  // The niches submitted by the operator. Stored as JSON so a future
  // worker can re-process a subset or annotate progress per-entry.
  queries       Json
  // Optional platform filter (null = all platforms). Mirrors the
  // single-search input shape.
  platform      String?
  limitPerQuery Int                  @default(20)
  status        DiscoveryBatchStatus @default(pending)
  // Accumulated result: per-niche records + totals. Worker updates on
  // each iteration. Shape mirrors `DiscoveryBatchSummaryZ` in
  // `@nosquare/shared`.
  summary       Json                 @default("{}")
  createdById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  completedAt   DateTime?

  @@index([status, createdAt])
  @@index([createdById])
}

// Standardized, queryable catalog row for a blogger/channel. Composed
// deterministically from ProfileDataPoint rows (latest high-confidence).
model BloggerProfile {
  id         String    @id @default(cuid())
  // Plain indexed reference to Channel.id (no FK relation to keep the
  // existing channel graph's cascade semantics untouched).
  channelId  String?   @unique
  topics     String[]  @default([])
  languages  String[]  @default([])
  formats    String[]  @default([])
  // Standardized rolled-up fields: { reach, avgViews, rateCards: [...],
  // audience: { age, gender, geo } }. Source of truth is dataPoints.
  audience   Json      @default("{}")
  rateCards  Json      @default("[]")
  reach      Int?
  avgViews   Int?
  capturedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  dataPoints   ProfileDataPoint[]
  mediaAssets  MediaAsset[]
  matchResults MatchResult[]
}

// One harvested fact with provenance, so the rolled-up profile can be
// re-derived and audited. Raw source text preserved in `rawSnippet`.
model ProfileDataPoint {
  id              String         @id @default(cuid())
  profileId       String
  profile         BloggerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  field           String
  value           Json
  unit            String?
  confidence      Decimal        @default(0)
  extractedBy     String         @default("llm")
  // Plain reference to Message.id (no FK relation).
  sourceMessageId String?
  rawSnippet      String         @default("")
  capturedAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())

  @@index([profileId, field])
}

// Files bloggers send (media kits, stat screenshots) and raw payload
// snapshots, stored in S3-compatible object storage.
model MediaAsset {
  id             String          @id @default(cuid())
  // Plain indexed reference to Conversation.id.
  conversationId String?
  profileId      String?
  profile        BloggerProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  kind           MediaAssetKind  @default(other)
  s3Key          String
  mime           String?
  bytes          Int?
  sha256         String?
  // Plain reference to the source TG message id.
  sourceTgMsgId  String?
  createdAt      DateTime        @default(now())

  @@index([conversationId])
  @@index([profileId])
}

// Incoming advertising request to match against the catalog.
model AdBrief {
  id             String    @id @default(cuid())
  topic          String
  audienceTarget String    @default("")
  budget         Int?
  formats        String[]  @default([])
  geo            String[]  @default([])
  deadline       DateTime?
  notes          String    @default("")
  createdById    String?
  createdAt      DateTime  @default(now())

  matchResults MatchResult[]
}

// A ranked candidate for a brief, persisted for auditability.
model MatchResult {
  id            String         @id @default(cuid())
  briefId       String
  brief         AdBrief        @relation(fields: [briefId], references: [id], onDelete: Cascade)
  profileId     String
  profile       BloggerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  score         Decimal        @default(0)
  rationale     String         @default("")
  rerankedByLlm Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@index([briefId])
  @@index([profileId])
}
