# --- Core ---
NODE_ENV=development
DATABASE_URL=postgresql://outreach:outreach@localhost:5432/outreach?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-prod-please-32-chars-long
ENCRYPTION_KEY=base64:AAECAwQFBgcICQoLDA0ODxAREhMUFRYXGBkaGxwdHh8=

# --- API / Web ---
API_PORT=4000
API_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# --- Telegram ---
TG_API_ID=
TG_API_HASH=
# Optional: pre-existing GramJS session string for an env-bootstrap parser
# account. On first connect SessionManager will save it into tg_account.
# session_encrypted (under id = TG_BOOTSTRAP_ACCOUNT_ID) so subsequent boots
# read the encrypted DB row.
TG_SESSION_STRING=
TG_BOOTSTRAP_ACCOUNT_ID=parser-default

# Optional proxy for the underlying GramJS client. Same proxy applies to all
# tg accounts (parser + outreach). Leave TG_PROXY_TYPE empty to disable.
# TG_PROXY_TYPE=socks5  # or "mtproxy"
TG_PROXY_TYPE=
TG_PROXY_IP=
TG_PROXY_PORT=
TG_PROXY_USERNAME=
TG_PROXY_PASSWORD=
TG_PROXY_SECRET=

# --- ScrapeCreators ---
SCRAPECREATORS_API_KEY=
SCRAPECREATORS_BASE_URL=https://api.scrapecreators.com

# --- LLM (опционально, можно создать endpoint в UI) ---
YANDEX_DEFAULT_FOLDER_ID=
YANDEX_API_KEY=
OPENROUTER_API_KEY=

# --- Logs ---
LOG_LEVEL=info
LOG_MESSAGE_BODIES=false

# --- Cost guards ---
COST_CAP_USD_PER_DAY=50
