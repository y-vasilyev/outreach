{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "./.tsbuildcache",
    "noEmit": false,
    "emitDeclarationOnly": true
  },
  "include": ["vite.config.ts"]
}
